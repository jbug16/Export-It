# Optional tuning
PORT=3001
JOB_DELAY_MS=3000
MAX_CONCURRENT_JOBS=1

# Optional: directory containing ffmpeg and ffprobe (auto-detected from Homebrew if unset)
# FFMPEG_PATH=/opt/homebrew/bin

# Metadata is fetched via spotDL (no Spotify API credentials required).
# Install spotDL: pipx install spotdl  OR  pip install spotdl
