PORT=3001

# Spotify OAuth (create app at https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Spotify requires 127.0.0.1 — localhost is rejected (see Spotify redirect URI docs)
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3001/api/spotify/callback

# Optional: default music output folder (can also set in app Settings)
# OUTPUT_DIR=/Users/you/Music
